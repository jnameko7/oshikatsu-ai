{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "oshikatsu-ai.vercel.app"
        }
      ],
      "destination": "https://www.oshikatsu-kakeibo.com/$1",
      "permanent": true
    }
  ]
}
{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/article/:slug",
      "destination": "/article.html"
    },
    {
      "source": "/articles",
      "destination": "/articles.html"
    },
    {
      "source": "/fund",
      "destination": "/fund.html"
    },
    {
      "source": "/saving",
      "destination": "/saving.html"
    },
    {
      "source": "/transport",
      "destination": "/transport.html"
    },
    {
      "source": "/yearly",
      "destination": "/yearly.html"
    },
    {
      "source": "/kakeibo",
      "destination": "/kakeibo.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    }
  ]
}
