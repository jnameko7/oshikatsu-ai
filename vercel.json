{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "oshikatsu-ai.vercel.app" }],
      "destination": "https://www.oshikatsu-kakeibo.com/$1",
      "permanent": true
    },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/article.html/:slug*", "destination": "/article/:slug*", "permanent": true },
    { "source": "/:path*.html", "destination": "/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/article/:slug*", "destination": "/article.html/:slug*" },
    { "source": "/article", "destination": "/article.html" }
  ]
}
