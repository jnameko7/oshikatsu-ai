{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "oshikatsu-ai.vercel.app" }
      ],
      "destination": "https://www.oshikatsu-kakeibo.com/$1",
      "permanent": true
    },
    {
      "source": "/article",
      "has": [
        { "type": "query", "key": "id", "value": "(?<slug>.*)" }
      ],
      "destination": "/article/:slug",
      "permanent": true
    },
    {
      "source": "/article.html",
      "has": [
        { "type": "query", "key": "id", "value": "(?<slug>.*)" }
      ],
      "destination": "/article/:slug",
      "permanent": true
    },
    { "source": "/articles.html", "destination": "/articles", "permanent": true },
    { "source": "/fund.html", "destination": "/fund", "permanent": true },
    { "source": "/saving.html", "destination": "/saving", "permanent": true },
    { "source": "/transport.html", "destination": "/transport", "permanent": true },
    { "source": "/yearly.html", "destination": "/yearly", "permanent": true },
    { "source": "/kakeibo.html", "destination": "/kakeibo", "permanent": true },
    { "source": "/terms.html", "destination": "/terms", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true }
  ],
  "rewrites": [
    { "source": "/article/:path*", "destination": "/article.html" }
    { "source": "/articles", "destination": "/articles.html" },
    { "source": "/fund", "destination": "/fund.html" },
    { "source": "/saving", "destination": "/saving.html" },
    { "source": "/transport", "destination": "/transport.html" },
    { "source": "/yearly", "destination": "/yearly.html" },
    { "source": "/kakeibo", "destination": "/kakeibo.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/contact", "destination": "/contact.html" }
  ]
}
